# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kraal:kraal_secret@localhost:5432/stellarkraal
POSTGRES_USER=kraal
POSTGRES_PASSWORD=kraal_secret
POSTGRES_DB=stellarkraal

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Stellar / Soroban ────────────────────────────────────────────────────────
STELLAR_NETWORK=mainnet
SOROBAN_RPC_URL=https://soroban-rpc.mainnet.stellar.gateway.fm
CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Frontend (Next.js public vars) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STELLAR_NETWORK=mainnet
NEXT_PUBLIC_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Oracle service ───────────────────────────────────────────────────────────
# JWT signed with JWT_SECRET, role=vet
ORACLE_JWT=replace-with-signed-oracle-jwt
ORACLE_POLL_INTERVAL_MS=300000
